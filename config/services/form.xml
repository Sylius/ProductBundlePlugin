<?xml version="1.0" encoding="UTF-8" ?>

<container xmlns="http://symfony.com/schema/dic/services" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">
    <parameters>
        <parameter key="sylius_product_bundle.form.type.product_bundle.validation_groups" type="collection">
            <parameter>sylius_product_bundle</parameter>
        </parameter>

        <parameter key="sylius_product_bundle.form.type.product_bundle_item.validation_groups" type="collection">
            <parameter>sylius_product_bundle</parameter>
        </parameter>
    </parameters>

    <services>
        <service id="sylius_product_bundle.form.type.product_bundle" class="Sylius\ProductBundlePlugin\Form\Type\ProductBundleType">
            <argument>%sylius_product_bundle.model.product_bundle.class%</argument>
            <argument>%sylius_product_bundle.form.type.product_bundle.validation_groups%</argument>
            <tag name="form.type" />
        </service>

        <service id="sylius_product_bundle.form.type.product_bundle_item" class="Sylius\ProductBundlePlugin\Form\Type\ProductBundleItemType">
            <argument>%sylius_product_bundle.model.product_bundle_item.class%</argument>
            <argument>%sylius_product_bundle.form.type.product_bundle_item.validation_groups%</argument>
            <tag name="form.type" />
        </service>

        <service id="sylius_product_bundle.form.extension.type.product" class="Sylius\ProductBundlePlugin\Form\Extension\ProductTypeExtension">
            <tag name="form.type_extension" extended-type="Sylius\Bundle\AdminBundle\Form\Type\ProductType" />
        </service>
    </services>
</container>
