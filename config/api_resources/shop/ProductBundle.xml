<resources
        xmlns="https://api-platform.com/schema/metadata/resources-3.0"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="https://api-platform.com/schema/metadata/resources-3.0 https://api-platform.com/schema/metadata/resources-3.0.xsd"
>
    <resource class="%sylius_product_bundle.model.product_bundle.class%" shortName="ProductBundle">
        <operations>
            <operation
                    name="shop_get_product-bundle"
                    class="ApiPlatform\Metadata\Get"
                    uriTemplate="/shop/product-bundles/{id}"
            >
                <normalizationContext>
                    <values>
                        <value name="groups">
                            <values>
                                <value>shop:product_bundle:read</value>
                            </values>
                        </value>
                    </values>
                </normalizationContext>
            </operation>

            <operation
                    name="shop_add_to_cart"
                    class="ApiPlatform\Metadata\Patch"
                    uriTemplate="/shop/product-bundles/{id}/add-to-cart"
                    messenger="input"
                    input="Sylius\ProductBundlePlugin\Command\AddProductBundleToCartCommand"
                    output="false"
            >
                <validationContext>
                    <values>
                        <value name="groups">
                            <values>
                                <value>sylius</value>
                            </values>
                        </value>
                    </values>
                </validationContext>
                <denormalizationContext>
                    <values>
                        <value name="groups">
                            <values>
                                <value>shop:product_bundle:add_to_cart</value>
                            </values>
                        </value>
                    </values>
                </denormalizationContext>
                <extraProperties>
                    <values>
                        <value name="summary">Adds the product bundle to the cart retrieved by token.</value>
                        <value name="responses">
                            <values>
                                <value name="200">
                                    <values>
                                        <value name="description">Product bundle added to the cart</value>
                                    </values>
                                </value>
                            </values>
                        </value>
                    </values>
                </extraProperties>
            </operation>
        </operations>
    </resource>
</resources>
